---
import art from '../content/art.json';

type Piece = {
  image: string;
  caption?: string;
};

type Category = {
  name: string;
  slug: string;
  display?: 'grid' | 'pages' | 'fade' | 'large';
  archived?: boolean;
  pieces: Piece[];
};

type YearGroup = {
  year: string;
  categories: Category[];
};

interface Props {
  archived?: boolean;
}

const { archived = false } = Astro.props;
const raw = art as YearGroup[];
// Filter categories by archived flag, drop years that end up empty
const years = raw
  .map((y) => ({ ...y, categories: y.categories.filter((c) => Boolean(c.archived) === archived) }))
  .filter((y) => y.categories.length > 0);
const heading = archived ? 'Archive' : 'Art';
---

<section class="px-6 py-16 max-w-5xl mx-auto">
  <div class="flex items-baseline justify-between gap-4">
    <h2 class="text-sm uppercase tracking-widest text-muted">{heading}</h2>
    {!archived && (
      <a href="/archive" class="text-xs text-muted underline decoration-muted underline-offset-4 hover:text-accent hover:decoration-accent">Archive →</a>
    )}
  </div>

  {years.map((y) => (
    <div class="mt-12" id={`art-${y.year}`}>
      <h3 class="text-2xl font-bold tracking-tight">{y.year}</h3>

      {y.categories.map((c) => (
        <div class="mt-8">
          <h4 class="text-sm font-semibold text-muted uppercase tracking-wider">{c.name}</h4>

          {c.pieces.length > 0 && c.display === 'fade' ? (
            <div class="mt-4">
              <button
                type="button"
                class="art-fade relative block w-full rounded-lg border border-border overflow-hidden bg-border/20 hover:border-accent transition-colors"
                data-category={c.name}
                aria-label={`${c.name} — loop of ${c.pieces.length} variations`}
              >
                {c.pieces.map((p, i) => (
                  <img
                    src={p.image}
                    alt={p.caption || c.name}
                    loading={i === 0 ? 'eager' : 'lazy'}
                    class="art-fade-frame w-full h-auto object-contain"
                    style={i === 0
                      ? 'opacity:1;transition:opacity 800ms ease-in-out;'
                      : 'position:absolute;inset:0;opacity:0;transition:opacity 800ms ease-in-out;'}
                  />
                ))}
              </button>
              <p class="mt-1 text-xs text-muted">Click to view full size · loop of {c.pieces.length} frames</p>
              <ul class="hidden">
                {c.pieces.map((p) => (
                  <li>
                    <button
                      type="button"
                      class="art-thumb"
                      data-image={p.image}
                      data-caption={p.caption || c.name}
                      data-category={c.name}
                    ></button>
                  </li>
                ))}
              </ul>
            </div>
          ) : c.pieces.length > 0 && c.display === 'pages' ? (
            <div class="mt-4 art-pager" data-category={c.name} data-total={c.pieces.length}>
              <div class="rounded-lg border border-border overflow-hidden bg-border/20">
                {c.pieces.map((p, i) => (
                  <button
                    type="button"
                    class={`art-pager-page art-thumb block w-full ${i === 0 ? '' : 'hidden'}`}
                    data-index={i}
                    data-image={p.image}
                    data-caption={p.caption || `${c.name} — page ${i + 1}`}
                    data-category={c.name}
                  >
                    <img
                      src={p.image}
                      alt={p.caption || `${c.name} page ${i + 1}`}
                      loading={i === 0 ? 'eager' : 'lazy'}
                      class="w-full h-auto object-contain"
                    />
                  </button>
                ))}
              </div>
              <div class="mt-3 flex items-center justify-between gap-3 text-sm">
                <button type="button" class="art-pager-prev rounded border border-border px-3 py-1 hover:border-accent disabled:opacity-40 disabled:cursor-not-allowed" disabled>← Prev</button>
                <span class="art-pager-counter text-xs text-muted">1 / {c.pieces.length}</span>
                <button type="button" class="art-pager-next rounded border border-border px-3 py-1 hover:border-accent disabled:opacity-40 disabled:cursor-not-allowed">Next →</button>
              </div>
            </div>
          ) : c.pieces.length > 0 ? (
            <ul class={`mt-4 grid gap-4 grid-cols-1 ${c.display === 'large' ? '' : 'sm:grid-cols-2'}`}>
              {c.pieces.map((p) => (
                <li>
                  <button
                    type="button"
                    class="art-thumb block w-full rounded-lg border border-border overflow-hidden bg-border/20 hover:border-accent transition-colors"
                    data-image={p.image}
                    data-caption={p.caption || c.name}
                    data-category={c.name}
                  >
                    <img
                      src={p.image}
                      alt={p.caption || c.name}
                      loading="lazy"
                      class="w-full h-auto object-contain"
                    />
                  </button>
                  {p.caption && (
                    <p class="mt-1 text-xs text-muted">{p.caption}</p>
                  )}
                </li>
              ))}
            </ul>
          ) : (
            <div class="mt-4 rounded-lg border border-dashed border-border px-4 py-6 text-center text-xs text-muted">
              No images yet — drop files into <code class="text-fg">public/art/{y.year}/{c.slug}/</code> and add them to <code class="text-fg">src/content/art.json</code>
            </div>
          )}
        </div>
      ))}
    </div>
  ))}
</section>

<div
  id="art-lightbox"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4 cursor-pointer"
  role="dialog"
  aria-modal="true"
  aria-label="Image viewer"
>
  <button
    id="art-lightbox-close"
    type="button"
    class="absolute top-4 right-4 text-white/80 hover:text-white text-3xl leading-none p-2"
    aria-label="Close"
  >×</button>
  <button
    id="art-lightbox-prev"
    type="button"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white text-5xl leading-none p-3"
    aria-label="Previous image"
  >‹</button>
  <button
    id="art-lightbox-next"
    type="button"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white/60 hover:text-white text-5xl leading-none p-3"
    aria-label="Next image"
  >›</button>
  <figure class="max-w-full max-h-full flex flex-col items-center gap-3" onclick="event.stopPropagation()">
    <img id="art-lightbox-img" src="" alt="" class="max-w-full max-h-[85vh] object-contain rounded shadow-2xl" />
    <figcaption id="art-lightbox-caption" class="text-sm text-white/70 text-center"></figcaption>
  </figure>
</div>

<script is:inline>
  (function () {
    const lightbox = document.getElementById('art-lightbox');
    const img = document.getElementById('art-lightbox-img');
    const caption = document.getElementById('art-lightbox-caption');
    const closeBtn = document.getElementById('art-lightbox-close');
    const prevBtn = document.getElementById('art-lightbox-prev');
    const nextBtn = document.getElementById('art-lightbox-next');
    // Fade-loop initialization (e.g. cubism deconstruction) — cycle frame opacity
    document.querySelectorAll('.art-fade').forEach((fade) => {
      const frames = Array.from(fade.querySelectorAll('.art-fade-frame'));
      if (frames.length < 2) return;
      // Equalize container height to the natural aspect of the first frame
      const first = frames[0];
      function setHeight() {
        if (first.naturalWidth && first.naturalHeight) {
          const ratio = first.naturalHeight / first.naturalWidth;
          fade.style.aspectRatio = `${first.naturalWidth} / ${first.naturalHeight}`;
        }
      }
      if (first.complete) setHeight();
      else first.addEventListener('load', setHeight, { once: true });
      let i = 0;
      setInterval(() => {
        frames[i].style.opacity = '0';
        i = (i + 1) % frames.length;
        frames[i].style.opacity = '1';
      }, 2500);
      // Clicking fade container opens lightbox with the currently visible frame
      fade.addEventListener('click', () => {
        const cat = fade.dataset.category;
        const list = document.querySelectorAll('.art-thumb');
        const match = Array.from(list).find((t) => t.dataset.category === cat && t.dataset.image === frames[i].src.replace(window.location.origin, ''));
        if (match) match.click();
      });
    });

    // Pager initialization (e.g. children's book) — only one page visible at a time
    document.querySelectorAll('.art-pager').forEach((pager) => {
      const pages = Array.from(pager.querySelectorAll('.art-pager-page'));
      const total = pages.length;
      const prevBtn = pager.querySelector('.art-pager-prev');
      const nextBtn = pager.querySelector('.art-pager-next');
      const counter = pager.querySelector('.art-pager-counter');
      let i = 0;
      function render() {
        pages.forEach((p, idx) => p.classList.toggle('hidden', idx !== i));
        counter.textContent = `${i + 1} / ${total}`;
        prevBtn.disabled = i === 0;
        nextBtn.disabled = i === total - 1;
      }
      prevBtn.addEventListener('click', () => { if (i > 0) { i--; render(); } });
      nextBtn.addEventListener('click', () => { if (i < total - 1) { i++; render(); } });
      render();
    });

    const thumbs = Array.from(document.querySelectorAll('.art-thumb'));

    // Group thumbs by category so arrow keys cycle within a category
    const groups = new Map();
    thumbs.forEach((t) => {
      const cat = t.dataset.category;
      if (!groups.has(cat)) groups.set(cat, []);
      groups.get(cat).push(t);
    });

    let currentGroup = [];
    let currentIndex = 0;

    function show(thumb) {
      const cat = thumb.dataset.category;
      currentGroup = groups.get(cat) || [thumb];
      currentIndex = currentGroup.indexOf(thumb);
      render();
      lightbox.classList.remove('hidden');
      lightbox.classList.add('flex');
      document.body.style.overflow = 'hidden';
    }

    function render() {
      const t = currentGroup[currentIndex];
      img.src = t.dataset.image;
      img.alt = t.dataset.caption || '';
      caption.textContent = currentGroup.length > 1
        ? `${t.dataset.category} — ${currentIndex + 1} / ${currentGroup.length}`
        : (t.dataset.caption || t.dataset.category);
      prevBtn.style.visibility = currentGroup.length > 1 ? 'visible' : 'hidden';
      nextBtn.style.visibility = currentGroup.length > 1 ? 'visible' : 'hidden';
    }

    function hide() {
      lightbox.classList.add('hidden');
      lightbox.classList.remove('flex');
      img.src = '';
      document.body.style.overflow = '';
    }

    function next() {
      currentIndex = (currentIndex + 1) % currentGroup.length;
      render();
    }

    function prev() {
      currentIndex = (currentIndex - 1 + currentGroup.length) % currentGroup.length;
      render();
    }

    thumbs.forEach((t) => t.addEventListener('click', () => show(t)));
    closeBtn.addEventListener('click', hide);
    lightbox.addEventListener('click', hide);
    prevBtn.addEventListener('click', (e) => { e.stopPropagation(); prev(); });
    nextBtn.addEventListener('click', (e) => { e.stopPropagation(); next(); });

    document.addEventListener('keydown', (e) => {
      if (lightbox.classList.contains('hidden')) return;
      if (e.key === 'Escape') hide();
      else if (e.key === 'ArrowRight') next();
      else if (e.key === 'ArrowLeft') prev();
    });
  })();
</script>
