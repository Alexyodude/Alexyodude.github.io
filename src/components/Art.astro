---
import art from '../content/art.json';

type Piece = {
  image: string;
  caption?: string;
};

type Category = {
  name: string;
  slug: string;
  pieces: Piece[];
};

type YearGroup = {
  year: string;
  categories: Category[];
};

const years = art as YearGroup[];
---

<section class="px-6 py-16 max-w-3xl mx-auto">
  <h2 class="text-sm uppercase tracking-widest text-muted">Art</h2>

  {years.map((y) => (
    <div class="mt-10">
      <h3 class="text-2xl font-bold tracking-tight">{y.year}</h3>

      {y.categories.map((c) => (
        <div class="mt-6">
          <h4 class="text-sm font-semibold text-muted uppercase tracking-wider">{c.name}</h4>

          {c.pieces.length > 0 ? (
            <ul class="mt-3 grid gap-3 grid-cols-2 md:grid-cols-3">
              {c.pieces.map((p) => (
                <li class="group">
                  <a href={p.image} target="_blank" rel="noopener" class="block">
                    <div class="aspect-square overflow-hidden rounded-lg border border-border bg-border/30">
                      <img
                        src={p.image}
                        alt={p.caption || c.name}
                        loading="lazy"
                        class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                      />
                    </div>
                    {p.caption && (
                      <p class="mt-1 text-xs text-muted">{p.caption}</p>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          ) : (
            <div class="mt-3 rounded-lg border border-dashed border-border px-4 py-6 text-center text-xs text-muted">
              No images yet — drop files into <code class="text-fg">public/art/{y.year}/{c.slug}/</code> and add them to <code class="text-fg">src/content/art.json</code>
            </div>
          )}
        </div>
      ))}
    </div>
  ))}
</section>
