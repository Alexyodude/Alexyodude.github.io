---
// Coordinate-based procedural universe. Astrobodies are generated per
// spatial chunk by hashing the chunk's world coordinates — so every visitor
// at the same (x, y, z) sees the same scene. Camera auto-drifts on +Z. The
// position persists in localStorage (and via ?x=&y=&z= URL params for shares).
// Visitors can teleport to any coordinate.
---

<canvas id="bg-stars" aria-hidden="true"></canvas>

<aside id="coord-panel" class="hidden md:block">
  <div class="coord-panel-title">COORDINATES (m)</div>
  <div class="coord-rows">
    <div><span>x</span><b id="coord-x">0</b></div>
    <div><span>y</span><b id="coord-y">0</b></div>
    <div><span>z</span><b id="coord-z">0</b></div>
  </div>
  <form id="coord-form" class="coord-form" autocomplete="off">
    <input id="coord-input" placeholder="x, y, z" aria-label="Teleport coordinates" spellcheck="false" />
    <button type="submit">Go</button>
  </form>
  <div class="coord-actions">
    <button type="button" id="coord-origin">↺ Origin</button>
    <button type="button" id="coord-random">⤳ Random</button>
    <button type="button" id="coord-pause">⏸ Pause</button>
  </div>
  <div class="coord-actions">
    <span class="coord-help" style="margin:0">time</span>
    <button type="button" class="coord-speed" data-mul="1">real</button>
    <button type="button" class="coord-speed" data-mul="86400">day/s</button>
    <button type="button" class="coord-speed" data-mul="31557600">yr/s</button>
    <button type="button" class="coord-speed" data-mul="31557600000">kyr/s</button>
  </div>
</aside>

<style>
  #bg-stars {
    position: fixed;
    inset: 0;
    width: 100vw;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }
  #coord-panel {
    position: fixed;
    left: 1rem;
    bottom: 1rem;
    z-index: 30;
    padding: 10px 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-bg) 75%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 11px;
    color: var(--color-fg);
    line-height: 1.4;
    min-width: 220px;
    max-width: 280px;
  }
  .coord-panel-title {
    color: var(--color-muted);
    letter-spacing: 0.12em;
    margin-bottom: 4px;
  }
  .coord-rows > div {
    display: grid;
    grid-template-columns: 1.5rem 1fr;
    align-items: baseline;
  }
  .coord-rows span {
    color: var(--color-muted);
    text-transform: uppercase;
  }
  .coord-rows b {
    font-weight: 500;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .coord-form {
    margin-top: 8px;
    display: flex;
    gap: 4px;
  }
  .coord-form input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    padding: 3px 6px;
    border-radius: 4px;
    font: inherit;
  }
  .coord-form input:focus {
    outline: none;
    border-color: var(--color-accent);
  }
  .coord-form button,
  .coord-actions button {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-fg);
    padding: 3px 8px;
    border-radius: 4px;
    font: inherit;
    cursor: pointer;
  }
  .coord-form button:hover,
  .coord-actions button:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }
  .coord-speed-active {
    border-color: var(--color-accent) !important;
    color: var(--color-accent) !important;
  }
  .coord-actions {
    margin-top: 6px;
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .coord-help {
    margin-top: 6px;
    color: var(--color-muted);
    font-size: 10px;
  }
</style>

<script is:inline>
(function () {
  function init() {
    const canvas = document.getElementById('bg-stars');
    if (!canvas) return;
    const ctx = canvas.getContext('2d', { alpha: true });

    // ===== world constants =====
    const STORAGE_KEY = 'universe.cam.v2';
    const RENDER_DISTANCE = 1e17;   // meters — about 10.6 light-years
    const CHUNK_SIZE      = 2e16;   // meters — about 2.1 light-years per chunk
    const N_RADIUS        = Math.ceil(RENDER_DISTANCE / CHUNK_SIZE); // chunks in each axis
    // Drift is fixed at c (speed of light). Apparent motion comes from a
    // simulated TIME dilation — visitors choose how many seconds of universe
    // time pass per real second. Default = 1 year/sec (≈ 1 light-year/sec).
    const C               = 299792458;
    const DRIFT_V         = C;          // m/s, fixed at speed of light
    const SEC_PER_DAY     = 86400;
    const SEC_PER_YEAR    = 31557600;
    let TIME_MUL          = SEC_PER_YEAR; // universe-seconds elapsed per real-second
    const TIME_DEFAULT    = SEC_PER_YEAR;
    const CACHE_LIMIT     = 50000;  // chunk cache hard limit
    const FOCAL_BASE      = 0.95;   // multiplier × max(w,h)

    // ===== state =====
    let cam = readInitial();
    let drifting = true;
    let lastFrameMs = performance.now();
    let lastSavedMs = 0;
    const chunkCache = new Map();

    function readInitial() {
      try {
        const u = new URLSearchParams(location.search);
        if (u.has('x') && u.has('y') && u.has('z')) {
          const a = ['x', 'y', 'z'].map((k) => parseFloat(u.get(k)));
          if (a.every(Number.isFinite)) return a;
        }
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) {
          const p = JSON.parse(stored);
          if (Array.isArray(p) && p.length === 3 && p.every(Number.isFinite)) return p;
        }
      } catch {}
      return [0, 0, 0];
    }

    function savePosition() {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(cam)); } catch {}
    }
    function updateUrl() {
      try {
        const u = new URL(location.href);
        u.searchParams.set('x', cam[0].toExponential(3));
        u.searchParams.set('y', cam[1].toExponential(3));
        u.searchParams.set('z', cam[2].toExponential(3));
        history.replaceState(null, '', u.pathname + u.search + u.hash);
      } catch {}
    }

    // ===== deterministic PRNG seeded from chunk coords =====
    function hashChunk(x, y, z) {
      let h = 0xA1EC0DE >>> 0;
      h = Math.imul(h ^ (x | 0), 0x85EBCA6B) >>> 0;
      h = Math.imul(h ^ (y | 0), 0xC2B2AE35) >>> 0;
      h = Math.imul(h ^ (z | 0), 0x27D4EB2F) >>> 0;
      h = (h ^ (h >>> 16)) >>> 0;
      return h || 1;
    }
    function mulberry32(seed) {
      let s = seed >>> 0;
      return function () {
        s = (s + 0x6D2B79F5) >>> 0;
        let t = s;
        t = Math.imul(t ^ (t >>> 15), t | 1);
        t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
        return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
      };
    }

    // ===== object types =====
    // Spectral classes, visually-weighted (real M dwarfs dominate by count but
    // are dim — we bias toward what'd actually appear in a dark sky).
    const SPECTRAL = [
      ['O',  [155, 176, 255], 0.005, 1.7],
      ['B',  [170, 191, 255], 0.04,  1.45],
      ['A',  [202, 215, 255], 0.08,  1.2],
      ['F',  [248, 247, 255], 0.12,  1.05],
      ['G',  [255, 244, 234], 0.18,  1.0],
      ['K',  [255, 210, 161], 0.27,  0.88],
      ['M',  [255, 160, 110], 0.305, 0.68],
    ];
    function pickSpectral(r) {
      let acc = 0;
      for (const c of SPECTRAL) {
        acc += c[2];
        if (r < acc) return c;
      }
      return SPECTRAL[SPECTRAL.length - 1];
    }

    const PLANET_PALETTE = [
      [180, 120, 80],   // rocky brown
      [200, 180, 130],  // sandy
      [110, 160, 220],  // ice/water
      [200, 90, 80],    // mars-red
      [230, 220, 200],  // pale
    ];
    const NEBULA_PALETTE = [
      [180, 100, 220],
      [220, 90, 150],
      [80, 160, 230],
      [230, 110, 90],
      [120, 200, 180],
    ];

    // ===== chunk generator =====
    function generateChunk(chx, chy, chz) {
      const r = mulberry32(hashChunk(chx, chy, chz));
      const cellRoll = r();
      // Most chunks empty — realistic interstellar sparsity
      let count = 0;
      if (cellRoll < 0.55) count = 0;
      else if (cellRoll < 0.92) count = 1;
      else if (cellRoll < 0.99) count = 2;
      else count = 3;

      const out = [];
      for (let i = 0; i < count; i++) {
        const wx = chx * CHUNK_SIZE + r() * CHUNK_SIZE;
        const wy = chy * CHUNK_SIZE + r() * CHUNK_SIZE;
        const wz = chz * CHUNK_SIZE + r() * CHUNK_SIZE;
        const t = r();
        const obj = { wx, wy, wz };
        if (t < 0.85) {
          const cls = pickSpectral(r());
          obj.type = 'star';
          obj.cr = cls[1][0];
          obj.cg = cls[1][1];
          obj.cb = cls[1][2];
          obj.sizeMul = cls[3];
          obj.bri = 0.5 + r() * 0.5;
        } else if (t < 0.95) {
          const p = PLANET_PALETTE[Math.floor(r() * PLANET_PALETTE.length)];
          obj.type = 'planet';
          obj.cr = p[0]; obj.cg = p[1]; obj.cb = p[2];
          obj.radius = 1.2 + r() * 3.5;
          obj.hasRing = r() < 0.18;
        } else if (t < 0.992) {
          const n = NEBULA_PALETTE[Math.floor(r() * NEBULA_PALETTE.length)];
          obj.type = 'nebula';
          obj.cr = n[0]; obj.cg = n[1]; obj.cb = n[2];
          obj.scale = 0.6 + r() * 1.4;
        } else {
          obj.type = 'blackhole';
          obj.scale = 0.5 + r() * 0.6;
        }
        out.push(obj);
      }
      return out;
    }

    function getChunk(chx, chy, chz) {
      const k = chx + '|' + chy + '|' + chz;
      let v = chunkCache.get(k);
      if (!v) {
        v = generateChunk(chx, chy, chz);
        if (chunkCache.size >= CACHE_LIMIT) {
          // Lazy eviction: drop oldest 20%
          let i = 0;
          const toDrop = Math.floor(CACHE_LIMIT * 0.2);
          for (const key of chunkCache.keys()) {
            if (i++ >= toDrop) break;
            chunkCache.delete(key);
          }
        }
        chunkCache.set(k, v);
      }
      return v;
    }

    // ===== viewport =====
    let W = 0, H = 0, cx = 0, cy = 0, dpr = 1, focal = 0;
    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      W = window.innerWidth;
      H = window.innerHeight;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      canvas.style.width = W + 'px';
      canvas.style.height = H + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      cx = W / 2; cy = H / 2;
      focal = Math.max(W, H) * FOCAL_BASE;
    }
    resize();
    window.addEventListener('resize', resize);

    function isDark() {
      return document.documentElement.getAttribute('data-theme') === 'dark';
    }

    // ===== UI =====
    const elX = document.getElementById('coord-x');
    const elY = document.getElementById('coord-y');
    const elZ = document.getElementById('coord-z');
    const inp = document.getElementById('coord-input');
    const form = document.getElementById('coord-form');
    const btnOrigin = document.getElementById('coord-origin');
    const btnRandom = document.getElementById('coord-random');
    const btnPause = document.getElementById('coord-pause');

    function fmt(n) {
      if (!Number.isFinite(n)) return '—';
      const a = Math.abs(n);
      if (a < 1000) return n.toFixed(0);
      return n.toExponential(3);
    }
    function refreshUI() {
      if (!elX) return;
      elX.textContent = fmt(cam[0]);
      elY.textContent = fmt(cam[1]);
      elZ.textContent = fmt(cam[2]);
    }
    refreshUI();

    function teleport(x, y, z) {
      cam = [x, y, z];
      refreshUI();
      savePosition();
      updateUrl();
    }

    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const raw = (inp.value || '').trim();
        if (!raw) return;
        const parts = raw.split(/[\s,]+/).map(Number);
        if (parts.length !== 3 || !parts.every(Number.isFinite)) {
          inp.style.borderColor = '#dc2626';
          setTimeout(() => { inp.style.borderColor = ''; }, 1200);
          return;
        }
        teleport(parts[0], parts[1], parts[2]);
        inp.value = '';
      });
    }
    if (btnOrigin) {
      btnOrigin.addEventListener('click', () => teleport(0, 0, 0));
    }
    if (btnRandom) {
      btnRandom.addEventListener('click', () => {
        // Jump to a random spot within a meaningful range
        const span = 1e18;
        teleport(
          (Math.random() - 0.5) * span,
          (Math.random() - 0.5) * span,
          (Math.random() - 0.5) * span
        );
      });
    }
    if (btnPause) {
      btnPause.addEventListener('click', () => {
        drifting = !drifting;
        btnPause.textContent = drifting ? '⏸ Pause' : '▶ Resume';
      });
    }
    document.querySelectorAll('.coord-speed').forEach((b) => {
      b.addEventListener('click', () => {
        const m = parseFloat(b.dataset.mul) || 1;
        TIME_MUL = m;
        document.querySelectorAll('.coord-speed').forEach((x) => x.classList.toggle('coord-speed-active', x === b));
      });
    });
    // Mark default active (1 year/sec)
    const defaultSpeed = document.querySelector('.coord-speed[data-mul="' + TIME_DEFAULT + '"]');
    if (defaultSpeed) defaultSpeed.classList.add('coord-speed-active');

    // ===== render =====
    function project(dx, dy, dz) {
      if (dz <= 1e6) return null; // behind/near plane (1 Mm)
      const k = focal / (dz / 1e15); // scale so that ~1e15 m maps reasonably
      return { px: cx + dx / 1e15 * k, py: cy + dy / 1e15 * k, k, dz };
    }

    function drawStar(px, py, color, alpha, size) {
      ctx.fillStyle = `rgba(${color},${alpha.toFixed(3)})`;
      ctx.fillRect(px - size / 2, py - size / 2, size, size);
    }

    function frame(nowMs) {
      const dt = Math.min(0.1, (nowMs - lastFrameMs) / 1000);
      lastFrameMs = nowMs;
      if (drifting) cam[2] += DRIFT_V * dt * TIME_MUL;
      if (nowMs - lastSavedMs > 500) {
        savePosition();
        updateUrl();
        refreshUI();
        lastSavedMs = nowMs;
      }

      ctx.clearRect(0, 0, W, H);
      const dark = isDark();
      // soft tint in light mode so stars read
      if (!dark) {
        ctx.fillStyle = 'rgba(245,247,250,0.5)';
        ctx.fillRect(0, 0, W, H);
      }

      const ccx = Math.floor(cam[0] / CHUNK_SIZE);
      const ccy = Math.floor(cam[1] / CHUNK_SIZE);
      const ccz = Math.floor(cam[2] / CHUNK_SIZE);

      // Iterate chunks in front of camera (plus small back margin for objects just passed)
      const minDz = -1;
      const maxDz = N_RADIUS;
      const renderD2 = RENDER_DISTANCE * RENDER_DISTANCE;

      // Two-pass: nebulae & black holes drawn separately to handle compositing
      const nebulaeDraw = [];
      const blackHolesDraw = [];

      for (let dx = -N_RADIUS; dx <= N_RADIUS; dx++) {
        for (let dy = -N_RADIUS; dy <= N_RADIUS; dy++) {
          for (let dz = minDz; dz <= maxDz; dz++) {
            const chx = ccx + dx;
            const chy = ccy + dy;
            const chz = ccz + dz;
            const objs = getChunk(chx, chy, chz);
            if (!objs.length) continue;
            for (const obj of objs) {
              const ox = obj.wx - cam[0];
              const oy = obj.wy - cam[1];
              const oz = obj.wz - cam[2];
              const d2 = ox * ox + oy * oy + oz * oz;
              if (d2 > renderD2) continue;
              const proj = project(ox, oy, oz);
              if (!proj) continue;
              if (proj.px < -50 || proj.px > W + 50 || proj.py < -50 || proj.py > H + 50) continue;

              const dist = Math.sqrt(d2);
              const depth = 1 - dist / RENDER_DISTANCE; // 0 (far) → 1 (near)

              if (obj.type === 'star') {
                const size = Math.max(0.5, depth * 3.2 * obj.sizeMul);
                const a = obj.bri * (0.15 + depth * 0.8);
                if (dark) {
                  drawStar(proj.px, proj.py, `${obj.cr},${obj.cg},${obj.cb}`, a, size);
                } else {
                  const rr = Math.min(60, Math.floor(255 - obj.cr) * 0.3 | 0);
                  const gg = Math.min(60, Math.floor(255 - obj.cg) * 0.3 | 0);
                  const bb = Math.min(60, Math.floor(255 - obj.cb) * 0.3 | 0);
                  drawStar(proj.px, proj.py, `${rr},${gg},${bb}`, a * 0.6, size);
                }
              } else if (obj.type === 'planet') {
                const rad = obj.radius * depth * 1.6;
                if (rad < 0.8) {
                  drawStar(proj.px, proj.py, `${obj.cr},${obj.cg},${obj.cb}`, 0.6 * depth, Math.max(0.6, rad));
                } else {
                  const grad = ctx.createRadialGradient(proj.px - rad * 0.35, proj.py - rad * 0.35, 0, proj.px, proj.py, rad);
                  grad.addColorStop(0, `rgba(${obj.cr + 30},${obj.cg + 30},${obj.cb + 30},${(0.95 * depth + 0.05).toFixed(2)})`);
                  grad.addColorStop(0.75, `rgba(${obj.cr},${obj.cg},${obj.cb},${(0.8 * depth + 0.1).toFixed(2)})`);
                  grad.addColorStop(1, `rgba(${(obj.cr * 0.5) | 0},${(obj.cg * 0.5) | 0},${(obj.cb * 0.5) | 0},${(0.6 * depth + 0.1).toFixed(2)})`);
                  ctx.fillStyle = grad;
                  ctx.beginPath();
                  ctx.arc(proj.px, proj.py, rad, 0, Math.PI * 2);
                  ctx.fill();
                  if (obj.hasRing && rad > 2) {
                    ctx.strokeStyle = `rgba(${obj.cr},${obj.cg},${obj.cb},${(0.5 * depth).toFixed(2)})`;
                    ctx.lineWidth = Math.max(0.6, rad * 0.18);
                    ctx.beginPath();
                    ctx.ellipse(proj.px, proj.py, rad * 1.7, rad * 0.45, 0.4, 0, Math.PI * 2);
                    ctx.stroke();
                  }
                }
              } else if (obj.type === 'nebula') {
                nebulaeDraw.push({ proj, obj, depth });
              } else if (obj.type === 'blackhole') {
                blackHolesDraw.push({ proj, obj, depth });
              }
            }
          }
        }
      }

      // Nebulae layer (additive in dark, multiply in light)
      if (nebulaeDraw.length) {
        ctx.globalCompositeOperation = dark ? 'lighter' : 'multiply';
        for (const n of nebulaeDraw) {
          const r = 200 * n.depth * n.obj.scale;
          if (r < 8) continue;
          const grad = ctx.createRadialGradient(n.proj.px, n.proj.py, 0, n.proj.px, n.proj.py, r);
          grad.addColorStop(0,   `rgba(${n.obj.cr},${n.obj.cg},${n.obj.cb},0.22)`);
          grad.addColorStop(0.4, `rgba(${n.obj.cr},${n.obj.cg},${n.obj.cb},0.07)`);
          grad.addColorStop(1,   `rgba(${n.obj.cr},${n.obj.cg},${n.obj.cb},0)`);
          ctx.fillStyle = grad;
          ctx.fillRect(n.proj.px - r, n.proj.py - r, r * 2, r * 2);
        }
        ctx.globalCompositeOperation = 'source-over';
      }

      // Black holes (drawn last)
      for (const bh of blackHolesDraw) {
        const r = 18 * bh.depth * bh.obj.scale;
        if (r < 3) continue;
        const halo = ctx.createRadialGradient(bh.proj.px, bh.proj.py, r * 0.5, bh.proj.px, bh.proj.py, r * 5);
        halo.addColorStop(0,   'rgba(255,180,90,0.5)');
        halo.addColorStop(0.2, 'rgba(255,120,40,0.2)');
        halo.addColorStop(0.5, 'rgba(120,60,200,0.08)');
        halo.addColorStop(1,   'rgba(0,0,0,0)');
        ctx.fillStyle = halo;
        ctx.fillRect(bh.proj.px - r * 5, bh.proj.py - r * 5, r * 10, r * 10);
        ctx.strokeStyle = 'rgba(255,210,140,0.85)';
        ctx.lineWidth = Math.max(1, r * 0.18);
        ctx.beginPath();
        ctx.arc(bh.proj.px, bh.proj.py, r * 0.75, 0, Math.PI * 2);
        ctx.stroke();
        ctx.fillStyle = '#000';
        ctx.beginPath();
        ctx.arc(bh.proj.px, bh.proj.py, r * 0.55, 0, Math.PI * 2);
        ctx.fill();
      }

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    // Save on unload too
    window.addEventListener('beforeunload', savePosition);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
